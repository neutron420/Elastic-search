generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ResearchPaper {
  id             String   @id @default(uuid())
  title          String
  abstract       String
  authors        String[]
  publishedDate  DateTime
  category       String
  keywords       String[]
  citationsCount Int      @default(0)
  price          Decimal  @default(0.0) @db.Decimal(10, 2)
  language       String   @default("en") @db.VarChar(5)
  journal        String
  doi            String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([language])
  @@index([citationsCount])
  @@map("research_papers")
}
